<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Beauty 911 – Login</title>
  <link rel="stylesheet" href="style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
</head>
<body class="login-page">

  <nav class="navbar">
    <div class="nav-logo">
      <span class="logo-icon">✦</span>
      <span class="logo-text">Beauty<span class="logo-accent">911</span></span>
    </div>
    <ul class="nav-links">
      <li><a href="login.html" class="active">Login</a></li>
      <li><a href="makeup.html">Makeup</a></li>
    </ul>
  </nav>

  
  <div class="bg-decor">
    <div class="petal petal-1"></div>
    <div class="petal petal-2"></div>
    <div class="petal petal-3"></div>
    <div class="petal petal-4"></div>
    <div class="petal petal-5"></div>
  </div>

  <main class="login-main">

    
    <div class="login-left">
      <div class="login-brand">
        <h1 class="brand-title">Welcome Back</h1>
        <p class="brand-sub">Your beauty journey awaits you.</p>
      </div>
      <div class="login-image-stack">
        <img src="https://images.unsplash.com/photo-1596462502278-27bfdc403348?w=400&q=80" alt="Makeup" class="img-card img-card-1"/>
        <img src="https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?w=400&q=80" alt="Beauty products" class="img-card img-card-2"/>
        <img src="https://images.unsplash.com/photo-1487412947147-5cebf100ffc2?w=400&q=80" alt="Lipstick" class="img-card img-card-3"/>
      </div>
      <div class="brand-tagline">
        <span class="tagline-line"></span>
        <p>"Redefining beauty, one look at a time."</p>
        <span class="tagline-line"></span>
      </div>
    </div>

    
    <div class="login-right">
      <div class="form-card">
        <div class="form-header">
          <div class="form-logo">✦ Beauty<span>911</span></div>
          <h2>Sign In</h2>
          <p>Access your personalized beauty dashboard</p>
        </div>

        <div class="tab-group">
          <button class="tab active" data-tab="login">Login</button>
          <button class="tab" data-tab="register">Register</button>
        </div>

    
        <form id="loginForm" class="auth-form active-form" novalidate>
          <div class="field-group">
            <label for="email">Email Address</label>
            <div class="input-wrapper">
              <span class="input-icon">✉</span>
              <input type="email" id="email" placeholder="you@example.com" autocomplete="email"/>
            </div>
            <span class="field-error" id="emailError"></span>
          </div>
          <div class="field-group">
            <label for="password">Password</label>
            <div class="input-wrapper">
              <span class="input-icon">🔒</span>
              <input type="password" id="password" placeholder="Enter your password" autocomplete="current-password"/>
              <button type="button" class="toggle-pass" id="togglePass" aria-label="Show password">👁</button>
            </div>
            <span class="field-error" id="passError"></span>
          </div>
          <div class="form-row">
            <label class="checkbox-label">
              <input type="checkbox" id="rememberMe"/>
              <span class="checkmark"></span>
              Remember me
            </label>
            <a href="#" class="forgot-link" id="forgotLink">Forgot password?</a>
          </div>
          <button type="submit" class="btn-primary" id="loginBtn">
            <span class="btn-text">Sign In</span>
            <span class="btn-icon">→</span>
          </button>
          <div class="divider"><span>or continue with</span></div>
          <div class="social-row">
            <button type="button" class="social-btn" id="googleBtn">
              <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.35-8.16 2.35-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
              Google
            </button>
            <button type="button" class="social-btn" id="fbBtn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073C24 5.404 18.627 0 12 0S0 5.404 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
              Facebook
            </button>
          </div>
        </form>

        
        <form id="registerForm" class="auth-form" novalidate>
          <div class="field-group">
            <label for="regName">Full Name</label>
            <div class="input-wrapper">
              <span class="input-icon">👤</span>
              <input type="text" id="regName" placeholder="Your full name"/>
            </div>
            <span class="field-error" id="regNameError"></span>
          </div>
          <div class="field-group">
            <label for="regEmail">Email Address</label>
            <div class="input-wrapper">
              <span class="input-icon">✉</span>
              <input type="email" id="regEmail" placeholder="you@example.com"/>
            </div>
            <span class="field-error" id="regEmailError"></span>
          </div>
          <div class="field-group">
            <label for="regPass">Password</label>
            <div class="input-wrapper">
              <span class="input-icon">🔒</span>
              <input type="password" id="regPass" placeholder="Create a password"/>
              <button type="button" class="toggle-pass" id="toggleRegPass">👁</button>
            </div>
            <div class="password-strength" id="passStrength">
              <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
              <span id="strengthLabel">Strength</span>
            </div>
            <span class="field-error" id="regPassError"></span>
          </div>
          <div class="field-group">
            <label for="regConfirm">Confirm Password</label>
            <div class="input-wrapper">
              <span class="input-icon">🔒</span>
              <input type="password" id="regConfirm" placeholder="Repeat password"/>
            </div>
            <span class="field-error" id="regConfirmError"></span>
          </div>
          <button type="submit" class="btn-primary">
            <span class="btn-text">Create Account</span>
            <span class="btn-icon">→</span>
          </button>
        </form>

        <div class="toast" id="toast"></div>
      </div>
    </div>
  </main>

  <div class="modal-overlay" id="forgotModal">
    <div class="modal-box">
      <button class="modal-close" id="closeModal">✕</button>
      <h3>Reset Password</h3>
      <p>Enter your email and we'll send you a reset link.</p>
      <div class="input-wrapper" style="margin-bottom:1rem;">
        <span class="input-icon">✉</span>
        <input type="email" id="resetEmail" placeholder="you@example.com"/>
      </div>
      <button class="btn-primary" id="sendResetBtn" style="width:100%;justify-content:center;">Send Reset Link</button>
    </div>
  </div>

  <script src="script.js"></script>
</body>
</html>
